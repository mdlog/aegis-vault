# ── Network ──
# Aristotle mainnet (chain 16661) — recommended for production operators
RPC_URL=https://evmrpc.0g.ai
CHAIN_ID=16661
# Galileo testnet (chain 16602) — for dev + staging
# RPC_URL=https://evmrpc-testnet.0g.ai
# CHAIN_ID=16602

# ── Executor (single-wallet mode) ──
# Primary executor private key. Vaults with matching vault.executor get managed by this orchestrator.
PRIVATE_KEY=0x_your_executor_private_key_here

# ── Executor pool (multi-wallet mode, RECOMMENDED for >10 vaults) ──
# Comma-separated list of executor private keys. Vaults are sharded
# deterministically across these wallets to avoid nonce collisions during
# parallel tx submission. Set vault.executor = walletForVault(address) at
# create time so each vault routes to its assigned shard.
# EXECUTOR_PRIVATE_KEYS=0xkey1,0xkey2,0xkey3

# ── Sealed-mode TEE signer ──
# Separate ECDSA key that signs EIP-712 intent hashes for sealed-mode vaults.
# Different from PRIVATE_KEY for defense-in-depth: executor wallet can submit
# txs but only TEE signer can authorize them. Vault.policy.attestedSigner must
# equal this wallet's address.
TEE_SIGNER_PRIVATE_KEY=0x_your_tee_signer_private_key_here

# ── Vault cycle concurrency ──
# How many vaults to process in parallel per cycle. Higher = more throughput,
# more RPC/Compute load. Default 5 works for most deployments.
# VAULT_CONCURRENCY=5

# ── Contract Addresses (from deployments.json after deploy) ──
VAULT_FACTORY_ADDRESS=0x...
EXECUTION_REGISTRY_ADDRESS=0x...
VAULT_ADDRESS=0x...
USDC_ADDRESS=0x...
WBTC_ADDRESS=0x...
WETH_ADDRESS=0x...

# ── Phase 1-5 production stack (optional — features degrade gracefully if missing) ──
PROTOCOL_TREASURY_ADDRESS=0x...
OPERATOR_REGISTRY_ADDRESS=0x...
OPERATOR_STAKING_ADDRESS=0x...
INSURANCE_POOL_ADDRESS=0x...
OPERATOR_REPUTATION_ADDRESS=0x...
AEGIS_GOVERNOR_ADDRESS=0x...

# ── 0G Compute ──
OG_COMPUTE_RPC=https://evmrpc.0g.ai
OG_COMPUTE_PRIVATE_KEY=0x_your_compute_private_key_here
OG_COMPUTE_MODEL=zai-org/GLM-5-FP8

# ── 0G Storage ──
# Aristotle mainnet (chain 16661) — production endpoints from
# docs.0g.ai/developer-hub/mainnet/mainnet-overview. Switch to testnet
# (Galileo) by uncommenting the alt block below.
OG_INDEXER_RPC=https://indexer-storage-turbo.0g.ai
OG_FLOW_CONTRACT=0x62D4144dB0F0a6fBBaeb6296c785C71B3D57C526
# Mainnet KV node URL is not yet officially published; leave empty so
# `kvGet` no-ops to local fallback. `kvSet` (write-side) continues to work
# via the indexer + Flow contract above. When 0G publishes a public KV
# node, set this to that URL.
OG_KV_RPC=
OG_STREAM_ID=
# Toggle on-chain submissions to 0G Storage. The mainnet FixedPriceFlow
# contract is currently rejecting our `submit()` calls with a bare
# `require(false)` — leaving this `false` skips kvSet + blob upload
# without spamming the log, while still letting the indexer reads work.
# Set to `true` once 0G ships an SDK update or documents the missing
# step.
OG_STORAGE_WRITES_ENABLED=false
#
# Galileo testnet alternates (uncomment to use):
# OG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
# OG_KV_RPC=http://3.101.147.150:6789
# OG_FLOW_CONTRACT=0x22E03a6A89B950F1c82ec5e74F8eCa321a105296

# ── Market Data ──
COINGECKO_API_URL=https://api.coingecko.com/api/v3

# ── Orchestrator ──
CYCLE_INTERVAL_MINUTES=5
PORT=4002
LOG_LEVEL=info
ORCHESTRATOR_API_KEY=

# ── Production fail-safe ──
# Set STRICT_MODE=1 for any deployment that custodies real funds.
# When enabled, the orchestrator will:
#   - Throw on CoinGecko / Pyth fetch failures (no synthetic prices)
#   - Throw on 0G Compute failures (no local heuristic fallback)
#   - Skip vaults whose operators are unregistered, unstaked, or whose stack is missing
STRICT_MODE=0

# Comma-separated allowlist of CORS origins. Empty = allow all (dev only).
# Production: set to your frontend domains, e.g. https://app.aegisvault.io,https://aegisvault.io
CORS_ALLOWED_ORIGINS=

# Optional structured-JSON log file (in addition to console)
LOG_FILE=

# Local persistent state directory. In staging / production point this at a
# durable volume mount. Relative paths resolve from the orchestrator cwd.
DATA_DIR=./data

# Optional fallback deployments file. If set, missing contract addresses are
# auto-filled from this JSON before startup validation runs.
DEPLOYMENTS_FILE=../contracts/deployments.json
