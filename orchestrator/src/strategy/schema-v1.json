{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegisvault.io/schemas/strategy-v1.json",
  "title": "Aegis Operator Strategy Manifest v1",
  "description": "Declarative strategy config for an Aegis Vault operator. Hash of the canonical JSON of this document is bound on-chain via OperatorRegistry.publishManifest and (in V4 vaults) per-intent via ExecutionIntent.strategyHash.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "strategy", "indicators", "scoring", "rules", "gates", "veto", "ai"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1,
      "description": "Schema major version. Backwards-compatible parsers in orchestrator may support multiple versions; vault-bound version is snapshot at create time."
    },
    "strategy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "type", "timeframe"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]{3,64}$" },
        "name": { "type": "string", "maxLength": 80 },
        "type": {
          "type": "string",
          "enum": ["momentum", "trend_following", "mean_reversion", "arbitrage", "market_neutral", "custom"]
        },
        "timeframe": { "type": "string", "enum": ["1m", "5m", "15m", "30m", "1h", "4h", "1d"] },
        "description": { "type": "string", "maxLength": 500 },
        "basedOn": { "type": ["string", "null"], "description": "Template id this strategy was forked from" },
        "basedOnHash": { "type": ["string", "null"], "pattern": "^0x[a-fA-F0-9]{64}$" }
      }
    },
    "indicators": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rsi": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "period": { "type": "integer", "minimum": 2, "maximum": 200, "default": 14 },
            "buyMin": { "type": "number", "minimum": 0, "maximum": 100 },
            "buyMax": { "type": "number", "minimum": 0, "maximum": 100 },
            "overbought": { "type": "number", "minimum": 50, "maximum": 100, "default": 70 },
            "oversold": { "type": "number", "minimum": 0, "maximum": 50, "default": 30 }
          }
        },
        "macd": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "fast": { "type": "integer", "minimum": 2, "maximum": 200, "default": 12 },
            "slow": { "type": "integer", "minimum": 2, "maximum": 200, "default": 26 },
            "signal": { "type": "integer", "minimum": 2, "maximum": 200, "default": 9 },
            "requireHistogramPositive": { "type": "boolean", "default": false }
          }
        },
        "ema": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "periods": {
              "type": "array",
              "items": { "type": "integer", "minimum": 2, "maximum": 500 },
              "minItems": 1,
              "maxItems": 5
            }
          }
        },
        "atr": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "period": { "type": "integer", "minimum": 2, "maximum": 200, "default": 14 }
          }
        },
        "vwap": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean", "default": true }
          }
        },
        "bollinger": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "period": { "type": "integer", "minimum": 5, "maximum": 200, "default": 20 },
            "stdDev": { "type": "number", "minimum": 0.5, "maximum": 5, "default": 2 }
          }
        }
      }
    },
    "scoring": {
      "type": "object",
      "additionalProperties": false,
      "required": ["weights"],
      "properties": {
        "weights": {
          "type": "object",
          "additionalProperties": false,
          "required": ["trend", "momentum", "volatility", "liquidity", "riskState", "aiContext"],
          "properties": {
            "trend": { "type": "number", "minimum": 0, "maximum": 1 },
            "momentum": { "type": "number", "minimum": 0, "maximum": 1 },
            "volatility": { "type": "number", "minimum": 0, "maximum": 1 },
            "liquidity": { "type": "number", "minimum": 0, "maximum": 1 },
            "riskState": { "type": "number", "minimum": 0, "maximum": 1 },
            "aiContext": { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "description": "Weights MUST sum to 1.0 (validator enforces tolerance ±0.01)"
        }
      }
    },
    "rules": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "entry_long": { "$ref": "#/$defs/rule" },
        "exit_long": { "$ref": "#/$defs/rule" },
        "entry_short": { "$ref": "#/$defs/rule" },
        "exit_short": { "$ref": "#/$defs/rule" },
        "size_bps": { "$ref": "#/$defs/expression" }
      }
    },
    "gates": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "minEdgeBuy": { "type": "integer", "minimum": 0, "maximum": 100 },
        "minQualityBuy": { "type": "integer", "minimum": 0, "maximum": 100 },
        "minConfidenceBuy": { "type": "number", "minimum": 0, "maximum": 1 },
        "maxRiskBuy": { "type": "number", "minimum": 0, "maximum": 1 },
        "minEdgeSell": { "type": "integer", "minimum": 0, "maximum": 100 },
        "minQualitySell": { "type": "integer", "minimum": 0, "maximum": 100 },
        "allowedBuyRegimes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["TREND_UP_STRONG", "TREND_UP_WEAK", "RANGE_STABLE", "RANGE_NOISY", "TREND_DOWN_WEAK", "TREND_DOWN_STRONG", "PANIC_VOLATILE", "LOW_LIQUIDITY"]
          }
        },
        "allowedSellRegimes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["TREND_UP_STRONG", "TREND_UP_WEAK", "RANGE_STABLE", "RANGE_NOISY", "TREND_DOWN_WEAK", "TREND_DOWN_STRONG", "PANIC_VOLATILE", "LOW_LIQUIDITY"]
          }
        }
      }
    },
    "veto": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxAtrPct": { "type": "number", "minimum": 0, "maximum": 100 },
        "rsiOverbought": { "type": "number", "minimum": 50, "maximum": 100 },
        "rsiOversold": { "type": "number", "minimum": 0, "maximum": 50 },
        "maxSpreadBps": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "maxSlippageBps": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "maxConsecutiveLosses": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },
    "ai": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "model", "providerAddress"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["scoring_input", "hard_gate", "context_only"],
          "description": "scoring_input: AI confidence/risk masuk formula scoring (default Aegis pattern). hard_gate: AI action sebagai filter — reject decision kalau AI disagree. context_only: AI cuma kasih context summary, tidak masuk decision math."
        },
        "model": { "type": "string", "minLength": 1, "maxLength": 128 },
        "providerAddress": { "type": "string", "pattern": "^0x[a-fA-F0-9]{40}$" },
        "endpoint": { "type": "string", "maxLength": 256 },
        "temperature": { "type": "number", "minimum": 0, "maximum": 2, "default": 0.3 },
        "scoringWeight": { "type": "number", "minimum": 0, "maximum": 1, "description": "Only honored when mode=scoring_input" },
        "systemPromptId": { "type": "string", "maxLength": 64, "description": "Reference to a prompt template" }
      }
    }
  },
  "$defs": {
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "expression": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024,
          "description": "Mini-DSL expression evaluating to boolean. Available identifiers: rsi_14, macd_histogram, ema_20, ema_50, ema_200, atr_14_pct, vwap_distance_pct, regime, ai.confidence, ai.risk_score, ai.ai_context_score, position.pnl_pct, vault.maxPositionBps, etc. Operators: && || ! == != < <= > >= + - * / in"
        }
      },
      "required": ["expression"]
    },
    "expression": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "expression": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512,
          "description": "Mini-DSL expression evaluating to a number. Same identifiers as rule. Helpers: min(), max(), clamp(x, lo, hi)"
        }
      },
      "required": ["expression"]
    }
  }
}
