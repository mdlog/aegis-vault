{
  "name": "orchestrator",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "cycle": "node -e \"import('./src/services/orchestrator.js').then(m => { m.initialize(); return m.runCycle(); }).then(r => { console.log(JSON.stringify(r, null, 2)); process.exit(0); })\"",
    "test": "node --test --test-reporter=spec test/*.test.js test/**/*.test.js",
    "test:backtester": "node --test --test-reporter=spec test/strategy/backtester.test.js",
    "backtest": "node scripts/backtest.mjs",
    "backtest:help": "node scripts/backtest.mjs --help"
  },
