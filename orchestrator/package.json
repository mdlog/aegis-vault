    "@sentry/node": "^10.50.0",
    "axios": "^1.15.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "p-limit": "^7.3.0",
    "winston": "^3.19.0"
