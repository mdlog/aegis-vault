VITE_ORCHESTRATOR_URL=http://localhost:4002
# NOTE: do NOT put ORCHESTRATOR_API_KEY here. Any VITE_* variable is inlined
# into the public JS bundle at build time, so it is not a secret. Mutation
# endpoints (/api/cycle, /api/og/flush) must be triggered out-of-band (curl
# with the key from orchestrator/.env), not from the browser.
# Live-mainnet first by default. Set to 1 only when you explicitly want showcase fallbacks.
VITE_ENABLE_DEMO_FALLBACKS=0
VITE_DISABLE_TESTNETS=0

# Clean-slate cutover for V4. Set to 1 to make the dashboard count and list
# ONLY V4 vaults (filtering out any pre-existing V1/V2/V3 test vaults that
# still live on-chain). Leave at 0 for normal operation where users with
# legacy vaults can still see them.
VITE_SHOW_ONLY_V4_VAULTS=0

# ── Sentry (error monitoring) ──
# Leave empty to disable Sentry entirely (it becomes a no-op).
# The DSN is public-by-design for browser SDKs — Sentry uses rate-limiting and
# source-IP filtering on its side, not DSN secrecy.
VITE_SENTRY_DSN=
# Optional: override the auto-detected environment (defaults to import.meta.env.MODE)
VITE_SENTRY_ENVIRONMENT=
# Optional: tag events with a release identifier (commit SHA, tag, etc.).
VITE_SENTRY_RELEASE=
# Performance trace sample rate. 0.0 = off, 1.0 = trace every transaction.
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
# Set to 1 to mask wallet addresses (0x1234…5678) in Sentry events.
# Off by default — addresses are public on-chain.
VITE_SENTRY_MASK_ADDRESSES=0
